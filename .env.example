##################################################################################
# NeurForge environment variables — basic configuration
# See `.env.full` for the full list.
#
# Use NEURFORGE_* prefixed variables (recommended).
# Legacy UTU_* variables are still accepted for backward compatibility.
##################################################################################

# =============================================
# LLM  (requires OpenAI-compatible API)
# =============================================
# ref: https://api-docs.deepseek.com/
NEURFORGE_LLM_TYPE=chat.completions
NEURFORGE_LLM_MODEL=deepseek-chat
NEURFORGE_LLM_BASE_URL=https://api.deepseek.com/v1
NEURFORGE_LLM_API_KEY=

# =============================================
# Tools
# =============================================
# --- search toolkit ---
# For web search, ref https://serper.dev/playground
SERPER_API_KEY=
# For web content extraction, ref https://jina.ai/reader
JINA_API_KEY=

# =============================================
# Misc (Optional)
# =============================================
# --- tracing ---
# OTEL endpoint (Optional), ref https://arize.com/docs/phoenix if use Phoenix
PHOENIX_ENDPOINT=
PHOENIX_PROJECT_NAME=neurforge
# additional key if use Phoenix's cloud service
PHOENIX_API_KEY=
# --- database ---
# database url (Optional), e.g., SQLite, PostgreSQL
NEURFORGE_DB_URL=sqlite:///neurforge.db
# --- logging ---
NEURFORGE_LOG_LEVEL=WARNING